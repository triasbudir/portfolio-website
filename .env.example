# Public site URL, used for SEO metadata, sitemap, and robots.txt
NEXT_PUBLIC_SITE_URL=https://portfolio-website-ecru-zeta-23.vercel.app

# Optional: enables the contact form to actually send emails via Resend (https://resend.com)
# Without this, submissions are just logged on the server.
RESEND_API_KEY=
CONTACT_TO_EMAIL=you@yourdomain.com
CONTACT_FROM_EMAIL=Portfolio Contact Form <onboarding@resend.dev>
